# ── Solana Wallet ─────────────────────────────────────────────
# Paste the JSON byte array from your wallet keypair file here
# Get it by running: cat ~/.config/solana/id.json
# It looks like: [12,34,56,...,78] — paste the entire array
SOLANA_PRIVATE_KEY=[12,34,56,...,78]

# ── OOBE Protocol ─────────────────────────────────────────────
# Your RPC URL from synapse.oobeprotocol.ai → dashboard → API Keys
# Mainnet format: https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=YOUR_KEY
# Staging format: https://staging.oobeprotocol.ai:8080/rpc?api_key=YOUR_KEY
SYNAPSE_RPC_URL=https://staging.oobeprotocol.ai:8080/rpc?api_key=YOUR_KEY_HERE

# ── Ace Data Cloud ────────────────────────────────────────────
# From platform.acedata.cloud → Account Token in sidebar
ACE_DATA_API_KEY=your_ace_data_token_here
ACE_DATA_BASE_URL=https://api.acedata.cloud

# ── Agent Config ──────────────────────────────────────────────
AGENT_NAME=SolanaIntelAgent
LOOP_INTERVAL_MS=600000

# ── Protocol Constants (never change these) ───────────────────
SENTINEL_WALLET=
SAP_PROGRAM_ID

# ── Dashboard API ─────────────────────────────────────────────
API_PORT=3001
